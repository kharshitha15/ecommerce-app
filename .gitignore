# Root .gitignore

# IDE & Editor Specific
.vscode/
.idea/
*.iws
*.iml
*.ipr
.project
.classpath
.settings/
.factorypath
.springBeans
.sts4-cache
*.log
*.tmp
*.temp
.DS_Store

# Backend (Spring Boot)
**/.mvn/wrapper/maven-wrapper.jar
**/boot_logs.txt
**/data/
**/target/

# Frontend (Node/Vite)
**/node_modules/
**/dist/
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Other common ignores
/.nx/cache
/out/
/bin/
**/build/
